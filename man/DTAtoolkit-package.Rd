\name{DTAtoolkit-package}
\alias{DTAtoolkit}
\alias{DTAtoolkit-package}
\docType{package}
\title{DTAtoolkit: Diagnostic Test Accuracy Meta-Analysis Workflows}
\description{
Wrapper functions and workflow utilities for streamlined diagnostic test
accuracy meta-analysis, including Reitsma models, forest plots, SROC plots,
influential-study analysis, bootstrap AUC estimation, and publication-bias tools.
}
\details{
The package provides pipe-oriented \code{dta_*} workflows using study-level
two-by-two table counts. See the package README and
\code{help("standardized-workflows")} for introductory examples.
}
\author{Payam PJD}
